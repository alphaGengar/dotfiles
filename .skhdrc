
# change window focus within space
shift + ctrl + cmd + alt - j : yabai -m window --focus south
shift + ctrl + cmd + alt - k : yabai -m window --focus north
shift + ctrl + cmd + alt - h : yabai -m window --focus west
shift + ctrl + cmd + alt - l : yabai -m window --focus east

# rotate layout clockwise
shift + ctrl + cmd + alt - r : yabai -m space --rotate 270

# flip along y-axis
shift + ctrl + cmd + alt - y : yabai -m space --mirror y-axis

# flip along x-axis
shift + ctrl + cmd + alt - x : yabai -m space --mirror x-axis

# toggle window float
shift + ctrl + cmd + alt - t : yabai -m window --toggle float --grid 4:4:1:1:2:270

# maximize a window
shift + ctrl + cmd + alt - m : yabai -m window --toggle zoom-fullscreen

# balance out tree of windows (resize to occupy same area)
shift + ctrl + cmd + alt - e : yabai -m space --balance

# make some windows a float
shift + ctrl + cmd + alt - f : yabai -m window --toggle float

# move window to display left and right
shift + ctrl + cmd + alt - s : yabai -m window --display west; yabai -m display --focus west;
shift + ctrl + cmd + alt - g : yabai -m window --display east; yabai -m display --focus east;

# move window to prev and next space
shift + ctrl + cmd + alt - p : yabai -m window --space prev;
shift + ctrl + cmd + alt - n : yabai -m window --space next;

# move window to space #
shift + ctrl + cmd + alt - 1 : yabai -m window --space 1;
shift + ctrl + cmd + alt - 2 : yabai -m window --space 2;
shift + ctrl + cmd + alt - 3 : yabai -m window --space 3;
shift + ctrl + cmd + alt - 4 : yabai -m window --space 4;
shift + ctrl + cmd + alt - 5 : yabai -m window --space 5;
shift + ctrl + cmd + alt - 6 : yabai -m window --space 6;
shift + ctrl + cmd + alt - 7 : yabai -m window --space 7;

# change the size of a window, directionally
shift + ctrl + cmd + alt - left : yabai -m window west --resize right:-20:0 2> /dev/null || yabai -m window --resize right:-20:0
shift + ctrl + cmd + alt - up : yabai -m window north --resize bottom:0:20 2> /dev/null || yabai -m window --resize bottom:0:20
shift + ctrl + cmd + alt - down : yabai -m window south --resize top:0:-20 2> /dev/null || yabai -m window --resize top:0:-20
shift + ctrl + cmd + alt - right : yabai -m window east --resize left:20:0 2> /dev/null || yabai -m window --resize left:20:0

# center a floating window
shift + ctrl + cmd + alt - a : yabai -m window --anchor

# stop/start/restart yabai
shift + ctrl + cmd + alt - q : yabai --stop-service
shift + ctrl + cmd + alt - 8 : yabai --start-service
shift + ctrl + cmd + alt - 0 : yabai --restart-service
